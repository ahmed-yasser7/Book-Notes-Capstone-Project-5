<%- include('partials/header', { title: 'Add Book' }) %>

<div class="page-hero">
  <h1>Add a Book</h1>
  <p>Log a book you have read.</p>
</div>

<div class="form-card">
  <form action="/add" method="POST">

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="title">Title</label>
        <input class="form-input" type="text" id="title" name="title" placeholder="Book title" required />
      </div>
      <div class="form-group">
        <label class="form-label" for="author">Author</label>
        <input class="form-input" type="text" id="author" name="author" placeholder="Author name" required />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="isbn">ISBN</label>
        <input class="form-input" type="text" id="isbn" name="isbn" placeholder="e.g. 9780141036144" maxlength="13" />
      </div>
      <div class="form-group">
        <label class="form-label" for="date_read">Date Read</label>
        <input class="form-input" type="date" id="date_read" name="date_read" required />
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="rating">Rating (1 - 10)</label>
      <input class="form-input" type="number" id="rating" name="rating" min="1" max="10" step="0.1" placeholder="8.5" required />
    </div>

    <div class="form-group">
      <label class="form-label" for="notes">Your Notes</label>
      <textarea class="form-textarea" id="notes" name="notes" placeholder="What did you think about this book?"></textarea>
    </div>

    <div class="form-actions">
      <a href="/" class="btn-secondary">Cancel</a>
      <button type="submit" class="btn-primary">Save Book</button>
    </div>

  </form>
</div>

<%- include('partials/footer') %>
