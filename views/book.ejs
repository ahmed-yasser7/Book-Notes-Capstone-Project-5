<%- include('partials/header', { title: book.title }) %>

<div class="page-hero">
  <a href="/" style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.875rem; color:var(--text-secondary); text-decoration:none; margin-bottom:1rem;">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M19 12H5M12 5l-7 7 7 7"/>
    </svg>
    Back to Library
  </a>
</div>

<div class="book-detail-card">

  <!-- Left: Cover -->
  <div class="book-detail-cover-wrap">
    <% if (book.isbn) { %>
      <img
        class="book-detail-cover"
        src="https://covers.openlibrary.org/b/isbn/<%= book.isbn %>-L.jpg"
        alt="<%= book.title %> cover"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="book-detail-placeholder" style="display:none;">
        <%= book.title.charAt(0) %>
      </div>
    <% } else { %>
      <div class="book-detail-placeholder">
        <%= book.title.charAt(0) %>
      </div>
    <% } %>
  </div>

  <!-- Right: Details -->
  <div class="book-detail-body">

    <h1 class="book-detail-title"><%= book.title %></h1>
    <p class="book-detail-author">by <%= book.author %></p>

    <!-- Rating -->
    <div class="book-rating" style="margin: 1.25rem 0;">
      <div class="rating-dots">
        <% for (let i = 1; i <= 10; i++) { %>
          <div class="rating-dot <%= i <= book.rating ? 'filled' : '' %>" style="width:10px; height:10px;"></div>
        <% } %>
      </div>
      <span class="rating-number" style="font-size:0.9rem;"><%= book.rating %> / 10</span>
    </div>

    <!-- Meta -->
    <div class="book-detail-meta">
      <div class="book-detail-meta-item">
        <span class="meta-label">Date Read</span>
        <span class="meta-value">
          <%= new Date(book.date_read).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </span>
      </div>
      <% if (book.isbn) { %>
        <div class="book-detail-meta-item">
          <span class="meta-label">ISBN</span>
          <span class="meta-value"><%= book.isbn %></span>
        </div>
      <% } %>
    </div>

    <!-- Notes -->
    <% if (book.notes) { %>
      <div class="book-detail-notes">
        <p class="meta-label" style="margin-bottom:0.75rem;">My Notes</p>
        <p class="notes-text"><%= book.notes %></p>
      </div>
    <% } %>

    <!-- Actions -->
    <div class="form-actions" style="margin-top: 2rem;">
      <a href="/edit/<%= book.id %>" class="btn-primary" style="text-decoration:none; text-align:center;">Edit Book</a>
      <form action="/delete/<%= book.id %>?_method=DELETE" method="POST">
        <button type="submit" class="btn-secondary"
          style="color:#dc2626; border-color:rgba(220,38,38,0.3);"
          onclick="return confirm('Delete this book?')">Delete</button>
      </form>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
